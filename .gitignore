# MediaVault .gitignore — local-only repo, no remote
# See README.md "Version control" section for tracking conventions.

# ---- Runtime database (mutable state, not source) ----
core/mediavault.sqlite
core/mediavault.sqlite-journal
core/mediavault.sqlite-wal
core/mediavault.sqlite-shm

# ---- Database backups (any suffix produced by migration / patch scripts) ----
*.sqlite.bak_*
*.sqlite.bak

# ---- Pre-refactor and pre-patch backup siblings of source files ----
# Deploy scripts produce *.pre_v0X_TIMESTAMP; manual edits produce *.bak_pre_*.
# These are point-in-time copies of files whose canonical version is tracked.
*.pre_v0*
*.bak_pre_*

# ---- Preserved v0.2-era reference copies ----
# STATE.md notes hr_manager.html.old_v02, core/imgserver.py.old_v02 etc. are
# kept on disk for reference. Duplicates already exist in the
# D:\AI_OK_TO_DELETE\MediaVault_v05_refactor_20260419\ quarantine; STATE.md
# documents what they are. No need to track the bytes too.
*.old_v02

# ---- Vault content (operator-collected bytes; potentially large) ----
# Spec §11 calls out catalogs/_assets and catalogs/_thumbs as the vault.
# Live layout also has catalogs/<domain>/_thumbs and catalogs/vaulted/.
# None of catalogs/ is source code.
catalogs/

# ---- Intake queues (transient inbound media — iOS captures, page screenshots) ----
intake/

# ---- Runtime thumbnail cache (separate from catalogs/ thumbnails) ----
thumbnails/

# ---- Python build artifacts ----
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ---- OS / editor noise ----
.DS_Store
Thumbs.db
*.swp
*.swo

# ---- Tag vocabulary cache (regenerated by tooling if it appears) ----
core/tag_vocabulary.json.bak

# --- backup hardening (added during off-machine backup setup) ---
mediavault.db
*.sqlite
*.db
.env
.dev.vars
*.key
*.pem
*.pre-*
*.pre_*
bak_*
_cowork/
core/backups/
core/__deltest*
core/__isotest
core/__test_sibling
